/* pages/register/register.wxss */
.register-container {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background-color: #f5f7fa;
}

.bg-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #f7e7c5, #dfb251);
}

.bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  animation: fadeIn 1s ease-out forwards;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.register-card {
  position: relative;
  z-index: 10;
  width: 80%;
  max-width: 400rpx;
  margin: 150rpx auto 0;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.title {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 50rpx;
}

.logo {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.name {
  font-size: 40rpx;
  font-weight: bold;
  color: #4a69bd;
}

.account-register {
  width: 100%;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-item {
  display: flex;
  align-items: center;
  background: rgba(240, 240, 240, 0.8);
  border-radius: 24rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
  height: 80rpx;
}

.input-item .icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  color: #666;
  width: 40rpx;
  text-align: center;
}

.input-item input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333;
}

.register-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #4a69bd, #3c5a99);
  color: white;
  border: none;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(74, 105, 189, 0.3);
  transition: transform 0.3s, box-shadow 0.3s;
}

.register-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(74, 105, 189, 0.2);
}

.login-area {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.login-btn {
  color: #4a69bd;
  margin-left: 10rpx;
  font-weight: bold;
}

.agreement {
  position: absolute;
  bottom: 50rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  z-index: 10;
}

.agreement navigator {
  color: rgba(255, 255, 255, 0.9);
  text-decoration: underline;
}