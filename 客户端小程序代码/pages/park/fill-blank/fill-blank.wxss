/* pages/park/fill-blank/fill-blank.wxss */
.page-container {
  min-height: 100vh;
  background-color: #f8f5e6;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 复用装饰和标题样式 */
.decor-top, .decor-bottom {
  height: 30rpx;
  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="%23d4b68c" fill-opacity="0.3" d="M0,128L48,144C96,160,192,192,288,186.7C384,181,480,139,576,138.7C672,139,768,181,864,181.3C960,181,1056,139,1152,122.7C1248,107,1344,117,1392,122.7L1440,128L1440,0L1392,0C1344,0,1248,0,1152,0C1056,0,960,0,864,0C768,0,672,0,576,0C480,0,384,0,288,0C192,0,96,0,48,0L0,0Z"></path></svg>');
  background-size: cover;
  background-repeat: no-repeat;
}
.decor-bottom { transform: rotate(180deg); }

.main-container {
  max-width: 700rpx;
  margin: 0 auto;
  padding: 40rpx 20rpx;
}

.title-box {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 60rpx 0 80rpx;
}
.title-decoration {
  width: 80rpx;
  height: 2rpx;
  background-color: #a07855;
}
.title-decoration.left { margin-right: 20rpx; }
.title-decoration.right { margin-left: 20rpx; }
.game-title {
  font-size: 40rpx;
  color: #8c6239;
  font-weight: 500;
  letter-spacing: 4rpx;
}

/* 新增：难度选择 */
.difficulty-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.difficulty-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
}

.difficulty-btn {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  margin: 0 10rpx;
  border-radius: 20rpx;
  background-color: #e0e0e0;
  color: #666;
  transition: all 0.3s ease;
}

.difficulty-btn.active {
  background-color: #8c6239;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(140, 98, 57, 0.3);
}

/* 新增：进度显示 */
.progress-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 1;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #8c6239;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 游戏样式 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #8c6239;
  font-size: 32rpx;
}

.question-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(160, 120, 85, 0.15);
  margin-bottom: 60rpx;
}

.poem-content {
  font-size: 36rpx;
  line-height: 1.8;
  color: #6b4c2f;
  text-align: center;
  margin-bottom: 40rpx;
  padding: 20rpx;
  background-color: #faf5ef;
  border-radius: 12rpx;
  border-left: 6rpx solid #8c6239;
}

.no-data {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 30rpx;
}

.poem-input {
  width: 70rpx;
  height: 70rpx;
  border: 2rpx solid #d4b68c;
  border-radius: 8rpx;
  padding: 0;
  box-sizing: border-box;
  font-size: 34rpx;
  color: #6b4c2f;
  text-align: center;
  margin: 0 4rpx;
  display: inline-block;
  vertical-align: middle;
}

.poem-input:focus {
  border-color: #a07855;
  outline: none;
}

.blanks-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.blank-item input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #d4b68c;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #6b4c2f;
}

.hint {
  font-size: 26rpx;
  color: #8c6239;
  opacity: 0.8;
}

.btn-group {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.submit-btn, .next-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #a07855;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 0;
}

.submit-btn:disabled {
  background-color: #d4b68c;
  opacity: 0.6;
}

.result-hint {
  text-align: center;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 60rpx;
  font-size: 32rpx;
}

.correct {
  color: #4cae4c;
}

.wrong {
  color: #d9534f;
}

.restart-btn {
  position: fixed;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  background-color: transparent;
  color: #8c6239;
  border: 2rpx solid #8c6239;
  border-radius: 35rpx;
  font-size: 28rpx;
  padding: 0;
}