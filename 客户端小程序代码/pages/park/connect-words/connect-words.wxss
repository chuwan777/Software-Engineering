/* pages/park/connect-words/connect-words.wxss */
/* 复用基础样式 */
.page-container {
  min-height: 100vh;
  background-color: #f8f5e6;
  padding: 20rpx;
  box-sizing: border-box;
}

.decor-top, .decor-bottom {
  height: 30rpx;
  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="%23d4b68c" fill-opacity="0.3" d="M0,128L48,144C96,160,192,192,288,186.7C384,181,480,139,576,138.7C672,139,768,181,864,181.3C960,181,1056,139,1152,122.7C1248,107,1344,117,1392,122.7L1440,128L1440,0L1392,0C1344,0,1248,0,1152,0C1056,0,960,0,864,0C768,0,672,0,576,0C480,0,384,0,288,0C192,0,96,0,48,0L0,0Z"></path></svg>');
  background-size: cover;
  background-repeat: no-repeat;
}
.decor-bottom { transform: rotate(180deg); }

.main-container {
  max-width: 700rpx;
  margin: 0 auto;
  padding: 40rpx 20rpx;
}

.title-box {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 60rpx 0 80rpx;
}
.title-decoration {
  width: 80rpx;
  height: 2rpx;
  background-color: #a07855;
}
.title-decoration.left { margin-right: 20rpx; }
.title-decoration.right { margin-left: 20rpx; }
.game-title {
  font-size: 40rpx;
  color: #8c6239;
  font-weight: 500;
  letter-spacing: 4rpx;
}

/* 游戏样式 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #8c6239;
  font-size: 32rpx;
}

.hint {
  display: block;
  text-align: center;
  font-size: 30rpx;
  color: #8c6239;
  margin-bottom: 30rpx;
}

.selected-words {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(160, 120, 85, 0.15);
  margin-bottom: 40rpx;
  min-height: 100rpx;
  align-items: center;
}

.word-item {
  display: flex;
  align-items: center;
  background-color: #f8f5e6;
  border: 2rpx solid #d4b68c;
  border-radius: 8rpx;
  padding: 10rpx 15rpx;
  font-size: 32rpx;
  color: #6b4c2f;
}

.delete {
  color: #d9534f;
  margin-left: 10rpx;
  font-size: 24rpx;
}

.word-pool {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 60rpx;
}

.word-btn {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #fff;
  border: 2rpx solid #a07855;
  border-radius: 12rpx;
  color: #6b4c2f;
  font-size: 32rpx;
  box-shadow: 0 4rpx 10rpx rgba(160, 120, 85, 0.1);
  cursor: pointer;
}

.submit-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #a07855;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 0;
  margin: 0 auto;
  display: block;
}

.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin: 40rpx 0;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(160, 120, 85, 0.15);
}

.result-card text {
  font-size: 32rpx;
  display: block;
  margin-bottom: 20rpx;
}

.correct-result { color: #4cae4c; }
.wrong-result { color: #d9534f; }

.correct-poem {
  font-size: 34rpx;
  color: #8c6239;
  margin: 20rpx 0;
  padding: 10rpx;
  background-color: rgba(160, 120, 85, 0.05);
  border-radius: 8rpx;
}

.restart-btn {
  background-color: transparent;
  color: #8c6239;
  border: 2rpx solid #8c6239;
  border-radius: 35rpx;
  font-size: 28rpx;
  padding: 0;
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  margin: 20rpx auto;
}
/* 新增状态栏样式 */
.status-bar {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 20rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #8c6239;
  background-color: rgba(255, 255, 255, 0.6);
  border-radius: 8rpx;
}

.streak {
  color: #e67700;
  font-weight: bold;
}

/* 错误提示样式 */
.error-box {
  text-align: center;
  padding: 80rpx 20rpx;
}

.error-msg {
  display: block;
  color: #d9534f;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}

.retry-btn {
  background-color: #a07855;
  color: #fff;
  border-radius: 35rpx;
  font-size: 28rpx;
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  padding: 0;
}

/* 提示按钮样式 */
.hint-btn {
  background-color: #f0e6d2;
  color: #8c6239;
  border: 2rpx solid #d4b68c;
  border-radius: 35rpx;
  font-size: 26rpx;
  padding: 0;
  width: 220rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0 0 30rpx auto;
  display: block;
}

/* 按钮交互反馈 */
.word-btn-active {
  transform: scale(0.95);
  background-color: #f0e6d2;
}

.submit-btn-active {
  background-color: #8c6239;
}

.restart-btn-active {
  background-color: rgba(140, 98, 57, 0.1);
}

/* 结果统计样式 */
.result-stats {
  margin: 30rpx 0;
  font-size: 28rpx;
  color: #6b4c2f;
}

.result-stats text {
  display: block;
  margin: 10rpx 0;
}

/* 优化已选字样式 */
.word-item {
  background-color: #f0e6d2;
  border-color: #a07855;
}