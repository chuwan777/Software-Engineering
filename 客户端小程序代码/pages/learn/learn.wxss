/* pages/learn/learn.wxss */

/* 页面背景色 */
page {
  background-color: #f7f5f2;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 卡片容器，设置统一的外边距 */
.poem-container {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx; /* 卡片之间的间距 */
}

/* 诗歌卡片样式 */
.poem-card {
  background-color: #ffffff;
  border-radius: 20rpx; /* 大圆角更现代 */
  overflow: hidden; /* 确保图片和内容不会超出圆角 */
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08); /* 轻微的阴影 */
  transition: all 0.3s ease-in-out; /* 过渡动画 */
  position: relative;
  display: flex;
  flex-direction: column;
}

.poem-card-hover {
  transform: translateY(-5rpx); /* 轻微上浮 */
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12); /* 加深阴影 */
}

/* 卡片 hover 效果 */
.poem-card:hover {
  transform: translateY(-5rpx); /* 轻微上浮 */
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1); /* 加深阴影 */
}

/* 诗歌图片 */
.poem-image {
  width: 100%;
  height: 240rpx; /* 固定图片高度 */
  object-fit: cover; /* 保证图片不变形，覆盖整个区域 */
}

/* 诗歌内容区域，设置内边距 */
.poem-content {
  padding: 30rpx;
}

/* 诗歌标题 */
.poem-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3748;
  font-family: 'STKaiti', 'KaiTi', serif; /* 使用楷体增强古韵 */
  display: block;
  margin-bottom: 12rpx;
}

/* 作者与难度信息行 */
.poem-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #718096;
  margin-bottom: 20rpx;
}

.poem-rating {
  color: #9f7aea; /* 用一个柔和的紫色突出评分 */
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background-color: rgba(159, 122, 234, 0.1);
}

/* 朝代徽章 */
.poem-dynasty-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 15rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: white;
}

.poem-dynasty-badge.tang {
  background: linear-gradient(135deg, #FF6B6B, #FFD166);
}

.poem-dynasty-badge.song {
  background: linear-gradient(135deg, #06D6A0, #118AB2);
}

.poem-dynasty-badge.other {
  background: linear-gradient(135deg, #8338EC, #3A86FF);
}


/* 诗歌原文 */
.poem-text {
  font-size: 28rpx;
  color: #4a5568;
  line-height: 1.8; /* 增加行高，提升可读性 */
  white-space: pre-wrap; /* 保留文本中的换行符 */
  font-family: 'STKaiti', 'KaiTi', serif;
}

/* 查看详情箭头 */
.poem-card-arrow {
  font-size: 30rpx;
  color: #ccc;
  margin-left: 12rpx;
  font-weight: 300;
  transition: all 0.3s ease;
}

.poem-card-hover .poem-card-arrow {
  color: #d4a066;
  transform: translateX(10rpx);
}

/* 加载中状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-container text {
  font-size: 28rpx;
  color: #718096;
}

/* 加载失败状态 */
.load-failed {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.load-failed text {
  font-size: 28rpx;
  color: #e53e3e;
  margin-bottom: 20rpx;
}

.retry-button {
  margin-top: 20rpx;
}

/* 空数据状态 */
.empty-data {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-data text {
  font-size: 28rpx;
  color: #718096;
}

/* 返回顶部按钮 */
.back-to-top {
  position: fixed;
  bottom: 100rpx;
  right: 40rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(212, 160, 102, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  opacity: 0;
  pointer-events: none;
  transform: translateY(30rpx) scale(0.8);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 999;
}

.back-to-top.show {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0) scale(1);
}

.back-to-top:active {
  transform: scale(0.9);
  transition: transform 0.1s ease;
}

.back-to-top-icon {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
}

/* AI小助手悬浮按钮 */
.ai-assistant-button {
  position: fixed;
  bottom: 200rpx;
  right: 40rpx;
  width: 90rpx;
  height: 90rpx;
  background-color: rgba(102, 160, 212, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(102, 160, 212, 0.4);
  transition: all 0.3s ease;
  z-index: 999;
  animation: pulse 2s infinite;
}

.ai-assistant-button:hover {
  transform: scale(1.1);
  box-shadow: 0 8rpx 25rpx rgba(102, 160, 212, 0.5);
}

.ai-assistant-button:active {
  transform: scale(0.95);
}

.ai-assistant-button.hide {
  opacity: 0;
  pointer-events: none;
  transform: translateY(30rpx) scale(0.8);
}

.ai-assistant-icon {
  font-size: 52rpx;
}

/* 呼吸动画 */
@keyframes pulse {
  0% {
    box-shadow: 0 0 0 0 rgba(102, 160, 212, 0.4);
  }
  70% {
    box-shadow: 0 0 0 20rpx rgba(102, 160, 212, 0);
  }
  100% {
    box-shadow: 0 0 0 0 rgba(102, 160, 212, 0);
  }
}

/* AI聊天界面容器 */
.ai-chat-container {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 80vh;
  max-height: 800rpx;
  background-color: white;
  border-radius: 30rpx 30rpx 0 0;
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 1000;
}

.ai-chat-container.show {
  transform: translateY(0);
}

/* 聊天头部 */
.ai-chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fafafa;
  border-radius: 30rpx 30rpx 0 0;
}

.ai-chat-header-right {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.ai-chat-title {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.ai-title-icon {
  font-size: 36rpx;
}

.ai-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.ai-chat-clear {
  font-size: 28rpx;
  color: #666;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background-color: #f0f0f0;
  transition: all 0.3s ease;
}

.ai-chat-clear:hover {
  background-color: #e0e0e0;
  color: #333;
}

.ai-chat-close {
  font-size: 48rpx;
  color: #999;
  cursor: pointer;
  transition: color 0.3s ease;
}

.ai-chat-close:hover {
  color: #333;
}

/* 聊天消息列表 */
.ai-chat-messages {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 消息样式 */
.ai-message {
  display: flex;
  margin-bottom: 20rpx;
  max-width: 80%;
  animation: messageSlideIn 0.3s ease-out;
}

/* 消息滑入动画 */
@keyframes messageSlideIn {
  0% {
    opacity: 0;
    transform: translateY(20rpx) scale(0.95);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.ai-user-message {
  align-self: flex-end;
  flex-direction: row-reverse;
}

.ai-assistant-message {
  align-self: flex-start;
}

/* 消息气泡 */
.ai-message-bubble {
  max-width: 100%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  word-wrap: break-word;
  word-break: break-all;
  line-height: 1.6;
  position: relative;
  transform-origin: bottom left;
}

.ai-user-message .ai-message-bubble {
  transform-origin: bottom right;
}

.user-bubble {
  background-color: #66a0d4;
  color: white;
  border-bottom-right-radius: 8rpx;
}

.assistant-bubble {
  background-color: #f5f5f5;
  color: #333;
  border-bottom-left-radius: 8rpx;
}

.ai-message-content {
  font-size: 28rpx;
}

/* 消息时间戳 */
.ai-message-time {
  font-size: 20rpx;
  opacity: 0.7;
  margin-top: 8rpx;
  display: block;
  text-align: right;
}

/* 加载中状态 */
.ai-loading {
  align-self: flex-start;
  padding: 15rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 15rpx;
}

.ai-loading-text {
  font-size: 24rpx;
  color: #666;
}

/* 聊天输入框 */
.ai-chat-input-container {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 30rpx 40rpx;
  border-top: 1rpx solid #f0f0f0;
  background-color: #fafafa;
}

.ai-chat-input {
  flex: 1;
  height: 80rpx;
  padding: 0 30rpx;
  background-color: white;
  border: 1rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.ai-chat-input:focus {
  border-color: #66a0d4;
  box-shadow: 0 0 0 4rpx rgba(102, 160, 212, 0.1);
}

.ai-chat-send-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: #66a0d4;
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  box-shadow: 0 4rpx 15rpx rgba(102, 160, 212, 0.3);
  transition: all 0.3s ease;
}

.ai-chat-send-btn:hover {
  background-color: #5590c4;
  transform: scale(1.05);
}

.ai-chat-send-btn:active {
  transform: scale(0.95);
}

.ai-chat-send-btn[disabled] {
  background-color: #ccc;
  box-shadow: none;
  transform: none;
  cursor: not-allowed;
}

.ai-send-icon {
  font-size: 24rpx;
  font-weight: 500;
}