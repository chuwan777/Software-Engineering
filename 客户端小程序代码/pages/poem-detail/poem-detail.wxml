<!-- pages/poem-detail/poem-detail.wxml -->
<page-meta>
  <navigation-bar 
    title="{{poem.title}}" 
    backgroundTextStyle="dark"
    color="#000000"
    background="#f7f5f2"
  />
</page-meta>

<view class="container">
<!-- 加载中状态 -->
<view class="loading-container" wx:if="{{isLoading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>

<!-- 加载失败状态 -->
<view class="error-container" wx:if="{{loadFailed}}">
  <icon type="warn" size="40" color="#ff4d4f"/>
  <text class="error-text">诗词加载失败</text>
  <button bindtap="retryLoad" class="retry-button">重试</button>
</view>

<!-- 诗词内容 -->
<view wx:else class="poem-container">
<!-- 诗词卡片 -->
<view class="poem-card">
  <!-- 标题和作者信息 -->
  <view class="poem-header">
    <text class="poem-title">{{poem.title}}</text>
    <text wx:if="{{from === 'system'}}" class="poem-author">{{poem.dynasty}} · {{poem.author}}</text>
    <text wx:elif="{{from === 'my'}}" class="poem-type">我的作品</text>
    <text wx:elif="{{from === 'collection'}}" class="poem-type">我的收藏</text>
  </view>

  <!-- 诗词图片 -->
  <view class="poem-image-container" wx:if="{{poem.image || poem.imgUrl || poem.imageUrl}}">
    <image class="poem-image" src="{{poem.image || poem.imgUrl || poem.imageUrl}}" mode="aspectFill" bindload="handleImageLoad" binderror="handleImageError"></image>
  </view>

    <!-- 诗词内容 -->
    <view class="poem-content-section">
      <view class="content-label">原文</view>
      <view class="poem-content">
        <text wx:for="{{contentLines}}" wx:key="*this" class="poem-line">{{item}}</text>
      </view>
    </view>
    
    <!-- 诗词译文 -->
    <view class="poem-content-section" wx:if="{{poem.translation}}">
      <view class="content-label">译文</view>
      <view class="poem-translation">
        <text class="translation-text">{{poem.translation}}</text>
      </view>
    </view>
    
    <!-- 诗词元信息 -->
    <view class="poem-meta">
      <text wx:if="{{from === 'system'}}" class="poem-tags">标签：{{poem.tags.join('、')}}</text>
      <text class="poem-views">浏览：{{poem.viewCount || 0}}</text>
      <text wx:if="{{from === 'my' || from === 'collection'}}" class="poem-date">创建：{{poem.createdAt}}</text>
    </view>
</view>
    
    <!-- 用户作品操作区域 -->
    <view wx:if="{{from === 'my'}}" class="user-poem-actions">
      <button class="action-btn edit-btn" bindtap="editPoem">
        <icon type="edit" size="20" color="#666"/>
        <text>编辑</text>
      </button>
      <button class="action-btn delete-btn" bindtap="deletePoem">
        <icon type="clear" size="20" color="#ff4d4f"/>
        <text>删除</text>
      </button>
    </view>
</view>

  <!-- 底部操作栏 -->
  <view class="action-bar" wx:if="{{!isLoading && !loadFailed}}">
    <view class="action-item" bindtap="handleShare">
      <icon type="share" size="20" color="#666"/>
      <text>分享</text>
    </view>
    <view class="action-item" wx:if="{{from !== 'my'}}" bindtap="handleCollect" data-id="{{poem.id}}">
      <icon type="{{isCollected ? 'collection' : 'addcollection'}}" size="20" color="{{isCollected ? '#ff4d4f' : '#666'}}"/>
      <text class="{{isCollected ? 'collected-text' : ''}}">{{isCollected ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="action-item" wx:if="{{from === 'system'}}" bindtap="markAsLearned">
      <icon type="success" size="20" color="#52c41a"/>
      <text>学习完成</text>
    </view>
    <view class="action-item" bindtap="savePoem">
      <icon type="success" size="20" color="#52c41a"/>
      <text>保存</text>
    </view>
  </view>
</view>
