/* pages/poem-detail/poem-detail.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.loading-text {
  color: #666;
  font-size: 28rpx;
}

/* 加载失败 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.error-text {
  color: #999;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}

.reload-btn {
  padding: 20rpx 60rpx;
  background-color: #1aad19;
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
}

/* 诗词内容 */
.poem-container {
  padding: 30rpx;
}

/* 诗词卡片 */
.poem-card {
  background-color: white;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 40rpx;
}

/* 诗词头部 */
.poem-header {
  margin-bottom: 30rpx;
  text-align: center;
}

.poem-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.poem-author {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.poem-type {
  font-size: 32rpx;
  color: #1aad19;
  margin-bottom: 10rpx;
  display: block;
  font-weight: bold;
}

/* 诗词内容区域包裹 */
.poem-content-section {
  margin-bottom: 30rpx;
}

/* 内容标签样式 */
.content-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 15rpx;
  padding-bottom: 8rpx;
  border-bottom: 2rpx solid #e0e0e0;
  display: inline-block;
}

/* 诗词内容 */
.poem-content {
  text-align: center;
}

.poem-line {
  display: block;
  font-size: 36rpx;
  line-height: 1.8;
  color: #333;
  margin-bottom: 10rpx;
}

/* 诗词译文容器 */
.poem-translation {
  background-color: #fafafa;
  padding: 25rpx;
  border-radius: 12rpx;
  margin-top: 10rpx;
}

/* 译文文本样式 */
.translation-text {
  font-size: 32rpx;
  line-height: 1.6;
  color: #555;
  text-align: justify;
}

/* 诗词图片容器 */
.poem-image-container {
  margin: 30rpx 0;
  overflow: hidden;
  border-radius: 16rpx;
  background-color: #f5f5f5;
}

/* 诗词图片 */
.poem-image {
  width: 100%;
  height: 300rpx;
  display: block;
  transition: transform 0.3s ease;
}

/* 图片悬停效果 */
.poem-image-container:active .poem-image {
  transform: scale(1.05);
}

/* 图片加载失败时的样式 */
.poem-image.err-img {
  opacity: 0.5;
}

/* 诗词元信息 */
.poem-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
  color: #999;
  font-size: 26rpx;
}

.poem-tags {
  flex: 1;
}

.poem-date {
  flex: 1;
  text-align: right;
}

/* 用户作品操作区域 */
.user-poem-actions {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: white;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.user-poem-actions .action-btn {
  flex: 1;
  margin: 0 10rpx;
  background-color: #f5f5f5;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
}

.user-poem-actions .edit-btn {
  background-color: #f0f9ff;
  color: #1890ff;
}

.user-poem-actions .delete-btn {
  background-color: #fff2f0;
  color: #ff4d4f;
}

/* 底部操作栏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx 0;
  background-color: white;
  border-top: 1rpx solid #f0f0f0;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
}

/* 操作按钮 */
.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 80rpx;
}

.action-item icon {
  margin-bottom: 8rpx;
}

.action-item text {
  font-size: 24rpx;
  color: #666;
}

.collected-text {
  color: #ff4d4f;
}