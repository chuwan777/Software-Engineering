/* pages/category/category.wxss */

/* 导入首页样式（核心复用，避免重复代码） */
@import "/pages/index/index.wxss";

/* 分类页面特有样式补充 */
.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 15px 0;
  padding-bottom: 10px;
  border-bottom: 1px solid #eee;
}

.category-title {
  font-size: 20px;
  font-weight: 600;
  color: #333;
}

.category-count {
  font-size: 14px;
  color: #999;
  background-color: #f5f5f5;
  padding: 3px 8px;
  border-radius: 12px;
}

/* 搜索结果区域样式 */
.search-results {
  margin-bottom: 20px;
}

.results-title {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 10px;
}

.no-results {
  text-align: center;
  padding: 40px 0;
  color: #999;
  font-size: 15px;
}

/* 加载失败样式 */
.load-failed {
  text-align: center;
  padding: 40px 0;
  color: #999;
}

.retry-button {
  margin-top: 10px;
  color: #07c160;
  border-color: #07c160;
}

/* 没有更多数据 */
.no-more {
  text-align: center;
  padding: 20px 0;
  color: #999;
  font-size: 14px;
}

/* 返回顶部按钮（与首页样式统一） */
.back-to-top {
  position: fixed;
  bottom: 30px;
  right: 20px;
  width: 40px;
  height: 40px;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: white;
  opacity: 0;
  transition: opacity 0.3s;
  z-index: 999;
}

.back-to-top.show {
  opacity: 1;
}