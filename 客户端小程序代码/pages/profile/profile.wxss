/* 我的页面样式 */
.container {
  background-color: #f5f7fa;
  color: #333;
  padding-bottom: 100rpx;
  min-height: 100vh;
  height: auto;
  overflow-y: auto;
  display: block;
}

/* 用户信息区域 */
.user-info {
  background: linear-gradient(135deg, #f7e7c5, #dfb251);
  color: white;
  padding: 50rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(106, 137, 204, 0.3);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
}

.user-info::before {
  content: "";
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  overflow: hidden;
  /* 确保容器本身是完美圆形 */
  box-sizing: border-box;
}

.user-avatar image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  /* 确保图片完全覆盖容器并保持比例 */
}

/* 头像占位符 */
.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.placeholder-icon {
  font-size: 64rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 懒加载头像过渡效果 */
.avatar-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  animation: fadeIn 0.3s ease-out forwards;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* 用户信息文字区域 */
.user-text-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-level {
  font-size: 28rpx;
  opacity: 0.9;
  display: inline-block;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
}

/* 我的诗库标题 */
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin: 50rpx 0 30rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid #4a69bd;
  color: #4a69bd;
}

/* 功能卡片区域 */
.card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 20rpx;
  padding-bottom: 100rpx;
}

/* 目标信息样式 */
.goal-info {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: rgba(255, 215, 0, 0.1);
  border-radius: 10rpx;
}

.goal-label {
  font-size: 28rpx;
  color: #666;
}

.goal-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffd700;
  margin: 0 10rpx;
}

.goal-status {
  font-size: 28rpx;
  color: #4caf50;
}

.goal-progress {
  margin-top: 10rpx;
  height: 8rpx;
  background-color: rgba(255, 215, 0, 0.2);
}

/* 模态框样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  width: 80%;
  max-width: 500rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  cursor: pointer;
  padding: 10rpx;
}

.modal-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
}

.form-input {
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 32rpx;
  text-align: center;
}

.form-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: -10rpx;
  text-align: center;
}

.submit-btn {
  background-color: #4caf50;
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
}

.submit-btn:hover {
  background-color: #45a049;
}

.card {
  background: white;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.3s, box-shadow 0.3s;
}

.card:active {
  transform: translateY(-10rpx);
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.1);
}

.card-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  font-size: 48rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

/* 学习进度卡片 */
.study-progress .card-icon {
  background-color: #e3f2fd;
  color: #2196f3;
}

.progress-bar {
  height: 16rpx;
  background-color: #e0e0e0;
  border-radius: 8rpx;
  margin-top: 20rpx;
  overflow: hidden;
}

.progress-value {
  height: 100%;
  border-radius: 8rpx;
  background-color: #4caf50;
}

/* 我的徽章卡片 */
.my-badges .card-icon {
  background-color: #fff8e1;
  color: #ff9800;
}

.badges-container {
  display: flex;
  margin-top: 20rpx;
}

.badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd54f, #ffb300);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: white;
  margin-right: 16rpx;
  color: white;
  font-size: 36rpx;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  text-align: center;
  color: #999;
}

.empty-state text:first-child {
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #bbb;
}

/* 加载动画样式 */
.loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 200rpx;
  font-size: 32rpx;
  color: #999;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 140, 0, 0.3);
  border-top-color: #ff8c00;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 我的收藏卡片 */
.my-collection .card-icon {
  background-color: #e8f5e9;
  color: #4caf50;
}

.collection-count {
  font-size: 48rpx;
  font-weight: bold;
  color: #4caf50;
  margin-top: 10rpx;
}

/* 录音作品卡片 */
.my-recordings .card-icon {
  background-color: #fce4ec;
  color: #e91e63;
}

.recordings-list {
  margin-top: 20rpx;
}

.recording-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.recording-item .icon {
  margin-right: 16rpx;
  color: #e91e63;
}

/* 其他功能区域 */
.other-functions {
  background: white;
  border-radius: 24rpx;
  padding: 0;
  overflow: hidden;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.05);
}

.function-item {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
  border-bottom: 1px solid #f0f0f0;
  transition: background-color 0.2s;
}

.function-item:last-child {
  border-bottom: none;
}

.function-item:active {
  background-color: #f9f9f9;
}

.function-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 30rpx;
  color: #4a69bd;
  font-size: 36rpx;
}

.function-name {
  flex: 1;
  font-size: 32rpx;
}

.arrow {
  color: #ccc;
  font-size: 32rpx;
}

/* 登录提示区域 */
.login-prompt {
  background: white;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.05);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.prompt-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
  color: #4a69bd;
}

.prompt-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 40rpx;
  line-height: 1.5;
  text-align: center;
}

.login-button {
  background: linear-gradient(135deg, #4a69bd, #3c5a99);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 80rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(74, 105, 189, 0.3);
  transition: transform 0.3s, box-shadow 0.3s;
}

.login-button:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(74, 105, 189, 0.2);
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  padding: 20rpx 0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.nav-item {
  flex: 1;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}

.nav-item.active {
  color: #4a69bd;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}