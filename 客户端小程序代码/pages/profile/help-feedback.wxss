/* help-feedback.wxss */
.help-feedback-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

/* 通用section样式 */
.section {
  background-color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.section-content {
}

/* 常见问题 */
.faq-list {
}

.faq-item {
  border-bottom: 1px solid #f0f0f0;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  font-size: 32rpx;
  color: #333;
}

.faq-toggle-icon {
  font-size: 24rpx;
  color: #666;
  margin-left: 20rpx;
}

.faq-answer {
  padding: 0 0 20rpx 20rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

/* 意见反馈 */
.feedback-type-container {
  margin-bottom: 30rpx;
}

.feedback-content-container {
  margin-bottom: 30rpx;
}

.contact-info-container {
  margin-bottom: 30rpx;
}

.image-upload-container {
  margin-bottom: 30rpx;
}

.feedback-label {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.feedback-type-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.feedback-type-item {
  padding: 15rpx 30rpx;
  border-radius: 50rpx;
  border: 2rpx solid #ddd;
  font-size: 28rpx;
  color: #666;
}

.feedback-type-item.selected {
  background-color: #007aff;
  color: white;
  border-color: #007aff;
}

.feedback-content {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.contact-info {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

/* 图片上传 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  width: 150rpx;
  height: 150rpx;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
}

.image-delete {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.7);
  color: white;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
}

.image-add {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed #ddd;
  border-radius: 10rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx;
  color: #ddd;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  background-color: #007aff;
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 32rpx;
}

/* 其他帮助 */
.help-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.help-option-btn {
  background-color: white;
  color: #007aff;
  border: 2rpx solid #007aff;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 32rpx;
}

.help-option-btn::after {
  border: none;
}