/* settings.wxss */
.settings-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 30rpx;
}

/* 用户信息卡片 */
.user-info-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background-color: white;
  margin-bottom: 20rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
}

.user-details {
  flex: 1;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-level {
  font-size: 28rpx;
  color: #666;
}

/* 设置列表 */
.settings-list {
  background-color: white;
  margin-bottom: 20rpx;
}

.setting-section {
  border-bottom: 1px solid #f0f0f0;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 25rpx 30rpx;
  background-color: #fafafa;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}



.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 30rpx;
  border-bottom: 1px solid #f5f5f5;
}

.setting-item:last-child {
  border-bottom: none;
}

.item-name {
  font-size: 32rpx;
  color: #333;
}

.item-right {
  display: flex;
  align-items: center;
}

.item-value {
  font-size: 30rpx;
  color: #999;
  margin-right: 10rpx;
}

.item-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 退出登录按钮 */
.logout-section {
  padding: 0 30rpx;
}

.logout-btn {
  width: 100%;
  height: 90rpx;
  background-color: #ff4d4f;
  color: white;
  border-radius: 10rpx;
  font-size: 32rpx;
  margin-top: 50rpx;
}

.logout-btn::after {
  border: none;
}