/* pages/profile/poems.wxss */
.poems-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.search-filter-bar {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 20rpx;
  background-color: white;
  padding: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 批量管理工具栏 */
.batch-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 2rpx solid #ff4d4f;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.batch-select-all {
  display: flex;
  align-items: center;
  gap: 10rpx;
  cursor: pointer;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  transition: all 0.3s;
}

.checkbox.checked {
  background-color: #ff4d4f;
  border-color: #ff4d4f;
}

.checkbox-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.select-all-text {
  font-size: 28rpx;
  color: #333;
}

.batch-info {
  font-size: 28rpx;
  color: #666;
}

.batch-delete-btn {
  font-size: 28rpx;
  padding: 10rpx 30rpx;
  border-radius: 10rpx;
}

/* 批量模式按钮 */
.batch-mode-button {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background-color: #fff;
  border: 2rpx solid #d9d9d9;
  border-radius: 20rpx;
  cursor: pointer;
  transition: all 0.3s;
}

.batch-mode-button:active {
  background-color: #f0f0f0;
}

.batch-icon {
  font-size: 28rpx;
}

.batch-text {
  font-size: 24rpx;
  color: #666;
}

/* 批量模式下的诗歌项 */
.poem-item.batch-mode {
  padding-left: 70rpx;
  position: relative;
}

.poem-select-box {
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  cursor: pointer;
}

.search-box {
  position: relative;
  display: flex;
  align-items: center;
}

.search-box input {
  flex: 1;
  height: 80rpx;
  padding: 0 30rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #333;
}

.search-actions {
  position: absolute;
  right: 20rpx;
  display: flex;
  align-items: center;
}

.search-box .clear-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  color: #666;
  font-size: 36rpx;
  line-height: 50rpx;
  text-align: center;
  padding: 0;
  margin: 0 10rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-btn {
  padding: 0 20rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  color: #fff;
  background-color: #07c160;
  border-radius: 30rpx;
}

.category-filter .picker {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 30rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
}

.poems-list {
  background-color: white;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.poem-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.2s;
}

.poem-item:last-child {
  border-bottom: none;
}

.poem-item:active {
  background-color: #f5f5f5;
  transform: scale(0.98);
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}

.poem-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.poem-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.poem-category {
  font-size: 24rpx;
  color: #666;
  background-color: #f0f0f0;
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
}

.poem-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  line-clamp: 3;
  -webkit-box-orient: vertical;
  margin-bottom: 15rpx;
}

.poem-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
}

.poem-date {
  font-size: 22rpx;
}

.poem-tags {
  font-size: 22rpx;
}

.empty-tip {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.loading-tip {
  padding: 50rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.load-more-tip {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
  background-color: #f9f9f9;
  margin-top: 20rpx;
}

.add-btn {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #07c160;
  color: white;
  font-size: 32rpx;
  box-shadow: 0 4rpx 15rpx rgba(7, 193, 96, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}
