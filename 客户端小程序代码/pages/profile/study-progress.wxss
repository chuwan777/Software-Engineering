/* 学习进度详情页样式 */
.container {
  padding: 20rpx;
  background-color: #FFFDF5;
  min-height: 100vh;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #FFE8B8;
  border-top-color: #FF8C00;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 进度概览 */
.progress-overview {
  margin-bottom: 30rpx;
}

.overview-card {
  display: flex;
  justify-content: space-around;
  background-color: #FFFFFF;
  padding: 30rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.item-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF8C00;
}

.item-label {
  font-size: 24rpx;
  color: #999;
}

/* 进度图表 */
.progress-chart {
  background-color: #FFFFFF;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}

.chart-container {
  width: 240rpx;
  height: 240rpx;
  position: relative;
}

.circular-progress {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF8C00;
  background-color: #FFFFFF;
  padding: 40rpx 60rpx;
  border-radius: 50%;
}

/* 今日目标 */
.daily-goal {
  background-color: #FFFFFF;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
}

.goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.goal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.goal-status {
  font-size: 28rpx;
  color: #28a745;
  font-weight: bold;
}

.progress-bar {
  height: 12rpx;
  background-color: #FFE8B8;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-value {
  height: 100%;
  background-color: #FF8C00;
  border-radius: 6rpx;
}

.goal-info {
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

/* 学习历史 */
.learning-history {
  background-color: #FFFFFF;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.history-count {
  font-size: 24rpx;
  color: #999;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.history-item {
  padding: 20rpx;
  border-radius: 12rpx;
  background-color: #FFF9E6;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  transition: background-color 0.3s;
}

.history-item:active {
  background-color: #FFE8B8;
}

.history-content {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.poem-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.poem-author {
  font-size: 22rpx;
  color: #999;
}

.history-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 5rpx;
}

.study-time {
  font-size: 20rpx;
  color: #999;
}

.study-status {
  font-size: 22rpx;
  color: #FF8C00;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #bbb;
}