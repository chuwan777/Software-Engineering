/* pages/profile/poem-edit.wxss */
.poem-edit-container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.input-group {
  margin-bottom: 30rpx;
  background-color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.label {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.input-group input {
  width: 100%;
  height: 80rpx;
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #e0e0e0;
  padding: 0;
  box-sizing: border-box;
}

.input-group textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 30rpx;
  color: #333;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  box-sizing: border-box;
  resize: vertical;
  line-height: 1.6;
}

.picker {
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  color: #666;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  background-color: #fafafa;
}

.save-btn {
  width: 100%;
  height: 90rpx;
  background-color: #07c160;
  color: white;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 10rpx;
  margin-top: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(7, 193, 96, 0.4);
}

.save-btn[disabled] {
  background-color: #ccc;
  box-shadow: none;
}
