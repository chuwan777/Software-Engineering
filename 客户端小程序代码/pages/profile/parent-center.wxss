/* parent-center.wxss */
.parent-center-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

/* 学习统计卡片 */
.stats-cards {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  width: calc(50% - 10rpx);
  background-color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #007aff;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 28rpx;
  color: #666;
}

/* 通用section样式 */
.section {
  background-color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.section-content {
}

.view-more {
  font-size: 28rpx;
  color: #007aff;
}

/* 每日学习目标 */
.goal-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goal-label {
  font-size: 32rpx;
  color: #333;
}

.goal-value {
  font-size: 32rpx;
  color: #007aff;
  padding: 10rpx 20rpx;
  border: 2rpx solid #007aff;
  border-radius: 5rpx;
}

/* 学习报告 */
.report-type-container {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.report-type-item {
  padding: 15rpx 30rpx;
  border-radius: 50rpx;
  border: 2rpx solid #ddd;
  font-size: 28rpx;
  color: #666;
}

.report-type-item.selected {
  background-color: #007aff;
  color: white;
  border-color: #007aff;
}

.view-report-btn {
  width: 100%;
  background-color: #007aff;
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 32rpx;
}

/* 学习记录 */
.record-list {
}

.record-item {
  padding: 20rpx 0;
  border-bottom: 1px solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
}

.record-time {
  font-size: 28rpx;
  color: #999;
  margin-right: 20rpx;
}

.record-content {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.record-status {
  font-size: 28rpx;
  padding: 5rpx 15rpx;
  border-radius: 50rpx;
  background-color: #e8f4fd;
  color: #007aff;
}

/* 设置按钮 */
.setting-btn {
  width: 100%;
  background-color: white;
  color: #007aff;
  border: 2rpx solid #007aff;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 32rpx;
}

.setting-btn::after {
  border: none;
}